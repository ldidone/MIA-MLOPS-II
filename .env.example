# Copy to .env and adjust as needed.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops
POSTGRES_DB=mlops

# --- MinIO (S3-compatible) --------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DATA_BUCKET=data-lake
MINIO_MLFLOW_BUCKET=mlflow-artifacts

# --- Shared AWS-style creds for MLflow / boto3 clients ---------------------
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
S3_ENDPOINT_URL=http://minio:9000

# --- MLflow -----------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=california_housing_regression
MODEL_NAME=california_housing_regressor
MODEL_ALIAS=champion

# --- Airflow ----------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW__CORE__FERNET_KEY=v3GS2WXmhHJd4iX3xHjYfQoUc-1gQxAMqLprZlbZDyg=

# --- App settings -----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://api:8000
APP_MODE=api            # api | embedded
LOCAL_MODEL_PATH=/app/models/model.pkl
LOG_LEVEL=INFO

# --- Dataset ----------------------------------------------------------------
# The California Housing dataset ships with scikit-learn; no external
# credentials are needed. The pipeline calls
# ``sklearn.datasets.fetch_california_housing`` and caches the raw CSV at
# ``data/raw/california_housing.csv``.
TARGET_COLUMN=MedHouseVal
